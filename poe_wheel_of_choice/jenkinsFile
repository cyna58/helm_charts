pipeline {
    agent {
        kubernetes {
            label 'helm-agent'
            defaultContainer 'helm'
            yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    app: jenkins-helm
spec:
  containers:
    - name: helm
      image: alpine/helm:4
      command:
        - cat
      tty: true
"""
        }
    }

    environment {
        HELM_RELEASE = "poe-woc"
        HELM_NAMESPACE = "jenkins"
        CHART_PATH = "."
    }

    stages {
        stage('Checkout Helm Charts') {
            steps {
                git branch: 'main', url: 'https://github.com/mcyliowski/helm_charts.git'
            }
        }

        stage('Deploy with Helm inside pod') {
            steps {
                sh """
                echo "CLI in container:"
                helm version

                helm upgrade --install \$HELM_RELEASE \$CHART_PATH \
                  --namespace \$HELM_NAMESPACE \
                  --values \$CHART_PATH/values.yaml
                """
            }
        }
    }
}
